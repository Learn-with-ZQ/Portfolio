# Google Apps Script Web App URL that appends contact-form submissions
# to your Google Sheet. See docs/CONTACT_FORM_SETUP.md for the 5-minute setup.
CONTACT_WEBHOOK_URL=

# Your production domain (used for SEO metadata, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=

# Optional Twitter/X handle for Twitter Card metadata (e.g. @yourhandle)
NEXT_PUBLIC_TWITTER_HANDLE=

# Search Console / webmaster verification (optional — add after claiming the site)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_VERIFICATION=
